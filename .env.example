APP_ENV=development
RAG_API_KEY=change-this-secret

POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql://rag_user:change-this-database-password@postgres:5432/rag_db

AI_PROVIDER=openai

OPENAI_API_KEY=put-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_OCR_MODEL=gpt-4o-mini

# USD prices per 1M tokens. Update these values if model pricing changes.
OPENAI_EMBEDDING_PRICE_PER_MILLION_TOKENS=0.02
OPENAI_CHAT_INPUT_PRICE_PER_MILLION_TOKENS=0.75
OPENAI_CHAT_CACHED_INPUT_PRICE_PER_MILLION_TOKENS=0.075
OPENAI_CHAT_OUTPUT_PRICE_PER_MILLION_TOKENS=4.50
OPENAI_OCR_INPUT_PRICE_PER_MILLION_TOKENS=0.15
OPENAI_OCR_CACHED_INPUT_PRICE_PER_MILLION_TOKENS=0.075
OPENAI_OCR_OUTPUT_PRICE_PER_MILLION_TOKENS=0.60

# Optional fallback provider
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite

UPLOAD_DIR=/code/app/uploads
TOP_K=5
EMBEDDING_DIM=768

# Token-aware semantic chunking and batched embeddings.
MAX_CHUNK_TOKENS=900
CHUNK_OVERLAP_TOKENS=120
MAX_CHUNK_CHARS=7000
CHUNK_OVERLAP_CHARS=500
MAX_CHUNKS_PER_DOCUMENT=0
EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUEST_DELAY_SECONDS=0

# Upload validation and duplicate protection.
MAX_UPLOAD_SIZE_MB=100
ALLOW_DUPLICATE_DOCUMENTS=false

# Hybrid retrieval: vector + PostgreSQL lexical search + exact token overlap.
RETRIEVAL_CANDIDATE_K=20
MIN_RELEVANCE_SCORE=0.20
VECTOR_WEIGHT=0.60
LEXICAL_WEIGHT=0.25
EXACT_MATCH_WEIGHT=0.15
NEIGHBOR_WINDOW=1
MAX_CONTEXT_CHUNKS=12

# Follow-up conversation memory and basic single-process rate limiting.
CONVERSATION_HISTORY_MESSAGES=6
RATE_LIMIT_REQUESTS_PER_MINUTE=120

ENABLE_OCR_FALLBACK=false
MAX_OCR_PAGES=10
OCR_RENDER_ZOOM=2.0
